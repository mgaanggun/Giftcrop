---
import HeaderLink from "./HeaderLink.astro";
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<div class="drawer-side z-50">
  <label for="my-drawer-2" aria-label="close sidebar" class="drawer-overlay"
  ><span class="sr-only">Open menu</span></label>
  <nav class="menu bg-base-200 min-h-full w-80 p-4 flex flex-col gap-3">
    <Logo />
	<hr class="opacity-20 my-4">
    <div class="flex items-center justify-between mb-2 px-4 rounded-xl bg-base-100 py-2">
      <span class="font-bold text-sm text-base-content">Tampilan Tema</span>
      <ThemeToggle id="theme-toggle-drawer" class="btn btn-sm btn-ghost btn-circle" />
    </div>
    <HeaderLink href="/">Beranda</HeaderLink>
    <HeaderLink href="/about">Tentang Kami</HeaderLink>
    <HeaderLink href="/services">Layanan</HeaderLink>
    <HeaderLink href="/produk">Produk</HeaderLink>
    <HeaderLink href="/blog">Blog</HeaderLink>
	<div class="mt-4 pt-4 border-t border-base-content/10">
		<a href="/contact" class="btn btn-block bg-[linear-gradient(125deg,var(--color-main-100),var(--color-main-200))] text-white border-0 shadow-md">Minta Penawaran</a>
	</div>
  </nav>
</div>
