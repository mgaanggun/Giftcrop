---
import HeaderLink from './HeaderLink.astro';
import { Menu } from '@lucide/astro';
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';
---

<header>
	<nav class="container flex justify-between py-4 items-center gap-2">
		<Logo />
		<div class="hidden lg:flex gap-10 items-center mx-auto">
			<HeaderLink href="/">Beranda</HeaderLink>
			<HeaderLink href="/about">Tentang Kami</HeaderLink>
			<HeaderLink href="/services">Layanan</HeaderLink>
			<HeaderLink href="/produk">Produk</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="flex items-center gap-1 sm:gap-2 ml-auto">
			<ThemeToggle />
			<a href="/contact" class="btn bg-[linear-gradient(125deg,var(--color-main-100),var(--color-main-200))] text-white border-0 rounded-xl text-xs sm:text-sm lg:text-lg py-2 px-3 sm:py-2 sm:px-4 lg:py-3 lg:px-6 h-auto shadow-xl hover:shadow-2xl hidden sm:inline-flex">Minta Penawaran</a>
			<label for="my-drawer-2" aria-label="open sidebar" class="btn btn-square btn-ghost lg:hidden p-0 sm:p-2 min-h-0 h-10 w-10">
				<Menu />
			</label>
		</div>
	</nav>
</header>
