{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/500/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/layanan/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/layanan/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/layanan/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/pesan/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/produk/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/produk/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/produk/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/submit-quote/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/faq/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/produk/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/produk/?$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/services(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/terms/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}